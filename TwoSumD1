#Brute Force

numbers = list(map(int, input().split()))
sortedNumbers = sorted(numbers)
target = int(input())

found = False

for i in range(len(sortedNumbers)):
    for j in range(i + 1, len(sortedNumbers)):
        if sortedNumbers[i] + sortedNumbers[j] == target:
            print(sortedNumbers[i])
            print(sortedNumbers[j])
            found = True
            break
    if found:
        break

if not found:
    print("Not found")


#Using HashMaps
numbers = list(map(int, input().split()))
target = int(input())

hashmap = {}

for num in numbers:
    complement = target - num

    if complement in hashmap:
        print(complement)
        print(num)
        break

    hashmap[num] = True
else:
    print("Not found")


    
