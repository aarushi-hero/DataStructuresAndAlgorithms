numbers = sorted(list(map(int, input("Enter numbers: ").split())))
target = int(input("Enter target: "))

i=0
j=len(numbers)-1
while(i<j):
    if (numbers[i]+numbers[j]==target):
        print(numbers[i])
        print(numbers[j])
        break
    elif (numbers[i]+numbers[j]<target):
        i+=1
    else:
        j-=1
